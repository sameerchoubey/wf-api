# Local development — copy to .env (never commit .env)

MONGO_URL=mongodb://localhost:27017
DB_NAME=wealthflow
JWT_SECRET=change-me-in-production
HTTP_ADDR=:8080
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,*

# Production (Fly.io) — set via CLI, not committed:
#   fly secrets set MONGO_URL="..." DB_NAME="wealthflow" JWT_SECRET="..." -a <your-app>
#   fly secrets set CORS_ORIGINS="https://your-app.web.app,*" -a <your-app>
